{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AKMessi/vex/schemas/open-visual-program-v1.json",
  "title": "Vex Open Visual Program v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "program_id",
    "signature",
    "evidence_signature",
    "seed",
    "canvas",
    "concept",
    "palette",
    "elements",
    "relations",
    "tracks",
    "constraints",
    "quality_contract"
  ],
  "properties": {
    "version": {"const": "vex-open-visual-program-v1"},
    "program_id": {"type": "string", "minLength": 1, "maxLength": 96},
    "signature": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_signature": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "seed": {"type": "integer", "minimum": 0},
    "canvas": {"$ref": "#/$defs/canvas"},
    "concept": {"$ref": "#/$defs/concept"},
    "palette": {"$ref": "#/$defs/palette"},
    "elements": {
      "type": "array",
      "minItems": 1,
      "maxItems": 48,
      "items": {"$ref": "#/$defs/element"}
    },
    "relations": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/$defs/relation"}
    },
    "tracks": {
      "type": "array",
      "maxItems": 96,
      "items": {"$ref": "#/$defs/track"}
    },
    "constraints": {
      "type": "array",
      "maxItems": 32,
      "items": {"$ref": "#/$defs/constraint"}
    },
    "quality_contract": {"type": "object"}
  },
  "$defs": {
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "duration_sec", "fps", "safe_area"],
      "properties": {
        "width": {"type": "integer", "minimum": 320, "maximum": 7680},
        "height": {"type": "integer", "minimum": 240, "maximum": 7680},
        "duration_sec": {"type": "number", "minimum": 1.2, "maximum": 16},
        "fps": {"type": "number", "minimum": 15, "maximum": 120},
        "safe_area": {
          "type": "object",
          "additionalProperties": false,
          "required": ["top", "right", "bottom", "left"],
          "properties": {
            "top": {"type": "number", "minimum": 0, "maximum": 0.2},
            "right": {"type": "number", "minimum": 0, "maximum": 0.2},
            "bottom": {"type": "number", "minimum": 0, "maximum": 0.2},
            "left": {"type": "number", "minimum": 0, "maximum": 0.2}
          }
        }
      }
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "medium", "metaphor", "composition", "takeaway"],
      "properties": {
        "title": {"type": "string", "maxLength": 160},
        "medium": {"type": "string", "minLength": 1, "maxLength": 80},
        "metaphor": {"type": "string", "minLength": 1, "maxLength": 240},
        "composition": {"type": "string", "minLength": 1, "maxLength": 240},
        "takeaway": {"type": "string", "maxLength": 240}
      }
    },
    "palette": {
      "type": "object",
      "additionalProperties": false,
      "required": ["background", "surface", "ink", "muted", "accent", "accent_secondary", "grid"],
      "properties": {
        "background": {"$ref": "#/$defs/color"},
        "surface": {"$ref": "#/$defs/color"},
        "ink": {"$ref": "#/$defs/color"},
        "muted": {"$ref": "#/$defs/color"},
        "accent": {"$ref": "#/$defs/color"},
        "accent_secondary": {"$ref": "#/$defs/color"},
        "grid": {"$ref": "#/$defs/color"}
      }
    },
    "color": {"type": "string", "pattern": "^#[0-9A-Fa-f]{6}(?:[0-9A-Fa-f]{2})?$"},
    "binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {"enum": ["fact", "object", "relation"]},
        "id": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height", "anchor"],
      "properties": {
        "x": {"type": "number", "minimum": 0, "maximum": 1},
        "y": {"type": "number", "minimum": 0, "maximum": 1},
        "width": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "height": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "anchor": {"enum": ["top_left", "center", "bottom_left", "bottom_right", "top_right"]}
      }
    },
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["element_id", "type", "role", "text", "decorative", "layout", "style", "repeat"],
      "properties": {
        "element_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "type": {"enum": ["chart", "connector", "group", "icon", "image", "mask", "metric", "particle", "path", "shape", "text", "token"]},
        "role": {"type": "string", "minLength": 1, "maxLength": 80},
        "text": {"type": "string", "maxLength": 240},
        "binding": {"$ref": "#/$defs/binding"},
        "decorative": {"type": "boolean"},
        "layout": {"$ref": "#/$defs/layout"},
        "style": {"type": "object"},
        "asset": {"type": "object"},
        "repeat": {"type": "integer", "minimum": 1, "maximum": 24}
      },
      "allOf": [
        {
          "if": {"properties": {"decorative": {"const": false}}},
          "then": {"required": ["binding"]}
        }
      ]
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_id", "source_id", "target_id", "type", "binding", "style"],
      "properties": {
        "relation_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "source_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "target_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "type": {"type": "string", "minLength": 1, "maxLength": 80},
        "binding": {"$ref": "#/$defs/binding"},
        "style": {"type": "object"}
      }
    },
    "track": {
      "type": "object",
      "additionalProperties": false,
      "required": ["track_id", "target_id", "property", "semantic_intent", "keyframes"],
      "properties": {
        "track_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "target_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "property": {"enum": ["blur", "emphasis", "opacity", "progress", "rotation", "scale", "translate_x", "translate_y"]},
        "semantic_intent": {"type": "string", "minLength": 1, "maxLength": 240},
        "keyframes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/keyframe"}
        }
      }
    },
    "keyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t", "value", "easing"],
      "properties": {
        "t": {"type": "number", "minimum": 0, "maximum": 1},
        "value": {"type": "number"},
        "easing": {"enum": ["ease_in", "ease_in_out", "ease_out", "linear", "spring_gentle", "spring_snappy"]}
      }
    },
    "constraint": {
      "type": "object",
      "required": ["constraint_id", "type", "targets"],
      "properties": {
        "constraint_id": {"type": "string", "minLength": 1, "maxLength": 96},
        "type": {"enum": ["align", "avoid_overlap", "contain", "distribute", "keep_inside_safe_area"]},
        "targets": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
